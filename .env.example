APP_ENV=local
HTTP_ADDR=:8080
DATABASE_URL=postgres://shop:shop@postgres:5432/shop?sslmode=disable

# Phase 3 Telegram webhook and catalog administration configuration.
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_WEBHOOK_SECRET=replace-with-at-least-16-random-characters
TELEGRAM_WEBHOOK_URL=http://localhost:8080/webhooks/telegram
ADMIN_TELEGRAM_IDS=123456789
SUPPORT_CONTACT=Vui lòng liên hệ quản trị viên cửa hàng.
TELEGRAM_WEBHOOK_BODY_LIMIT_BYTES=1048576
TELEGRAM_WEBHOOK_TIMEOUT_SECONDS=5
TELEGRAM_UPDATE_STALE_SECONDS=120
ADMIN_SESSION_TTL_MINUTES=15
TELEGRAM_API_TIMEOUT_SECONDS=5

# Exactly 32 random bytes, standard-base64 encoded. Generate a real key with:
# openssl rand -base64 32
INVENTORY_ENCRYPTION_KEY=replace-with-standard-base64-encoded-32-byte-key
INVENTORY_ENCRYPTION_KEY_VERSION=1
INVENTORY_IMPORT_MAX_ITEMS=100
INVENTORY_IMPORT_MAX_ITEM_BYTES=4096
INVENTORY_IMPORT_MAX_TOTAL_BYTES=262144

# Dedicated key for bank account numbers. Do not reuse the inventory key in production.
BANK_ACCOUNT_ENCRYPTION_KEY=replace-with-standard-base64-encoded-32-byte-key
BANK_ACCOUNT_ENCRYPTION_KEY_VERSION=1

ORDER_EXPIRE_MINUTES=15
ORDER_MAX_QUANTITY=10
PAYMENT_REFERENCE_PREFIX=TS
PAYMENT_REFERENCE_RANDOM_BYTES=6
VIETQR_BASE_URL=https://img.vietqr.io/image/
VIETQR_TEMPLATE=compact2
ORDER_PAGE_SIZE=8
BANK_ACCOUNT_PAGE_SIZE=8

# Provider-neutral payment automation. No production adapter is bundled.
# signed_json is limited to development/test and must never be enabled in production.
PAYMENT_PROVIDERS=
PAYMENT_PRIMARY_PROVIDER=
PAYMENT_PROVIDER_ENVIRONMENT=development
SIGNED_JSON_WEBHOOK_SECRET=
SIGNED_JSON_TIMESTAMP_TOLERANCE=300
PAYMENT_WEBHOOK_BODY_LIMIT=1048576
PAYMENT_EVENT_BATCH_SIZE=100
PAYMENT_EVENT_POLL_INTERVAL=5
PAYMENT_EVENT_RUN_TIMEOUT=10
PAYMENT_EVENT_MAX_ATTEMPTS=5
PAYMENT_EVENT_RETRY_BASE=5
PAYMENT_STALE_PROCESSING_TIMEOUT=120
WALLET_TOPUP_MIN_AMOUNT=10000
WALLET_TOPUP_MAX_AMOUNT=10000000
WALLET_TOPUP_EXPIRE_MINUTES=15
WALLET_PAGE_SIZE=8
PAYMENT_REVIEW_PAGE_SIZE=8
PAYMENT_PROVIDER_REVIEW_PAGE_SIZE=8
PAYMENT_RECONCILIATION_ENABLED=false
PAYMENT_RECONCILIATION_INTERVAL=1m
PAYMENT_RECONCILIATION_RUN_TIMEOUT=30s
PAYMENT_RECONCILIATION_REQUEST_TIMEOUT=10s
PAYMENT_RECONCILIATION_MAX_PAGES=10
PAYMENT_RECONCILIATION_PAGE_SIZE=100

# Worker-only order expiry settings (seconds except batch size).
ORDER_EXPIRY_INTERVAL=30
ORDER_EXPIRY_BATCH_SIZE=100
ORDER_EXPIRY_RUN_TIMEOUT=10

# Durable Telegram delivery worker. Durations use Go duration syntax.
DELIVERY_BATCH_SIZE=25
DELIVERY_POLL_INTERVAL=5s
DELIVERY_RUN_TIMEOUT=30s
DELIVERY_JOB_TIMEOUT=10s
DELIVERY_PROCESSING_LEASE=2m
DELIVERY_MAX_ATTEMPTS=5
DELIVERY_RETRY_BASE=5s
DELIVERY_RETRY_MAX=5m
DELIVERY_RETRY_JITTER=0.20
DELIVERY_STALE_SCAN_INTERVAL=30s
DELIVERY_MESSAGE_MAX_BYTES=3500
DELIVERY_REVIEW_PAGE_SIZE=8
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true
SHUTDOWN_TIMEOUT_SECONDS=10

DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=2
DATABASE_CONNECTION_TTL_MINUTES=30
DATABASE_HEALTH_TIMEOUT_SECONDS=2
MIGRATIONS_DIR=migrations
